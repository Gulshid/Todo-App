<?xml version="1.0" encoding="utf-8"?>
<!--
    item_todo.xml — Flutter-style card with:
    - Left colored priority bar
    - Title + optional description
    - Category chip
    - Edit + Delete buttons
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/todoCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="5dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@color/card_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="4dp">

        <!-- Priority color bar -->
        <View
            android:id="@+id/priorityBar"
            android:layout_width="4dp"
            android:layout_height="52dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/priority_bar_shape"/>

        <!-- Checkbox -->
        <CheckBox
            android:id="@+id/cbComplete"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="8dp"
            android:buttonTint="@color/checkbox_tint"/>

        <!-- Content -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingVertical="10dp">

            <TextView
                android:id="@+id/tvTodoTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/text_primary"
                android:maxLines="2"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/tvTodoDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:fontFamily="sans-serif-light"
                android:textColor="@color/text_secondary"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginTop="2dp"
                android:visibility="gone"/>

            <!-- Category chip -->
            <TextView
                android:id="@+id/tvCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:textSize="10sp"
                android:textColor="@color/accent_teal"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/category_chip_bg"
                android:letterSpacing="0.04"/>

        </LinearLayout>

        <!-- Action buttons -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginEnd="4dp">

            <ImageButton
                android:id="@+id/btnEdit"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_edit"
                android:background="@drawable/icon_btn_bg"
                android:tint="@color/text_secondary"
                android:padding="8dp"
                android:contentDescription="Edit"/>

            <ImageButton
                android:id="@+id/btnDelete"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_delete"
                android:background="@drawable/icon_btn_bg"
                android:tint="@color/priority_high"
                android:padding="8dp"
                android:layout_marginStart="4dp"
                android:contentDescription="Delete"/>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>